{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stardew-agent.local/schemas/action-plan.schema.json",
  "title": "Stardew Agent Action Plan v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "plan_id", "expected_observation_id", "goal", "actions", "stop_conditions", "request_replan_after"],
  "properties": {
    "schema_version": {"const": "2.0"},
    "plan_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "expected_observation_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "goal": {"type": "string", "minLength": 1, "maxLength": 512},
    "actions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {"$ref": "#/$defs/action"}
    },
    "stop_conditions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["energy_below", "game_time_at_or_after", "max_failures"],
      "properties": {
        "energy_below": {"type": "number", "minimum": 0, "maximum": 1000},
        "game_time_at_or_after": {"type": "integer", "minimum": 600, "maximum": 2600},
        "max_failures": {"type": "integer", "minimum": 0, "maximum": 64}
      }
    },
    "request_replan_after": {"type": "boolean"}
  },
  "$defs": {
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "action", "args"],
      "properties": {
        "action_id": {"type": "string", "minLength": 1, "maxLength": 128},
        "action": {
          "enum": ["travel_to", "clear_debris", "plant_crop", "water_crop", "refill_watering_can", "harvest_crop", "buy_item", "ship_items", "wait_until", "sleep", "advance_dialogue", "choose_response", "dismiss_menu", "finish"]
        },
        "args": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "target_id": {"type": "string", "minLength": 1},
            "target_revision": {"type": "string", "minLength": 1},
            "destination": {"enum": ["Farm", "FarmHouse", "BusStop", "Town", "SeedShop"]},
            "qualified_item_id": {"type": "string", "minLength": 1},
            "offer_id": {"type": "string", "minLength": 1},
            "offer_revision": {"type": "string", "minLength": 1},
            "quantity": {"type": "integer", "minimum": 1, "maximum": 999},
            "source_id": {"type": "string", "minLength": 1},
            "water_after_planting": {"type": "boolean"},
            "selector_item_ids": {"type": "array", "maxItems": 64, "items": {"type": "string", "minLength": 1}},
            "category": {"enum": ["crop", "forage", "seed"]},
            "time": {"type": "integer", "minimum": 600, "maximum": 2600},
            "response_id": {"type": "string", "minLength": 1},
            "reason": {"type": "string", "minLength": 1, "maxLength": 256}
          }
        },
        "continue_on": {
          "type": "array",
          "uniqueItems": true,
          "items": {"enum": ["ALREADY_SATISFIED", "TARGET_UNREACHABLE"]}
        }
      },
      "allOf": [
        {
          "if": {"properties": {"action": {"enum": ["clear_debris", "plant_crop", "water_crop", "harvest_crop"]}}},
          "then": {"properties": {"args": {"required": ["target_id", "target_revision"]}}}
        },
        {
          "if": {"properties": {"action": {"const": "travel_to"}}},
          "then": {"properties": {"args": {"required": ["destination"]}}}
        },
        {
          "if": {"properties": {"action": {"const": "plant_crop"}}},
          "then": {"properties": {"args": {"required": ["qualified_item_id", "water_after_planting"]}}}
        },
        {
          "if": {"properties": {"action": {"const": "buy_item"}}},
          "then": {"properties": {"args": {"required": ["offer_id", "offer_revision", "quantity"]}}}
        },
        {
          "if": {"properties": {"action": {"const": "ship_items"}}},
          "then": {
            "properties": {"args": {"anyOf": [{"required": ["selector_item_ids"]}, {"required": ["category"]}]}}
          }
        },
        {
          "if": {"properties": {"action": {"const": "wait_until"}}},
          "then": {"properties": {"args": {"required": ["time"]}}}
        },
        {
          "if": {"properties": {"action": {"const": "choose_response"}}},
          "then": {"properties": {"args": {"required": ["response_id"]}}}
        },
        {
          "if": {"properties": {"action": {"const": "finish"}}},
          "then": {"properties": {"args": {"required": ["reason"]}}}
        }
      ]
    }
  }
}
