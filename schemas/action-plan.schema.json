{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stardew-agent.local/schemas/action-plan.schema.json",
  "title": "Stardew Agent Action Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "plan_id", "expected_observation_id", "goal", "actions", "stop_conditions", "request_replan_after"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "plan_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "expected_observation_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "goal": {"type": "string", "minLength": 1, "maxLength": 512},
    "actions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {"$ref": "#/$defs/action"}
    },
    "stop_conditions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["energy_below", "game_time_at_or_after", "max_failures"],
      "properties": {
        "energy_below": {"type": "number", "minimum": 0, "maximum": 1000},
        "game_time_at_or_after": {"type": "integer", "minimum": 600, "maximum": 2600},
        "max_failures": {"type": "integer", "minimum": 0, "maximum": 64}
      }
    },
    "request_replan_after": {"type": "boolean"}
  },
  "$defs": {
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "action", "args"],
      "properties": {
        "action_id": {"type": "string", "minLength": 1, "maxLength": 128},
        "action": {
          "enum": ["move_to", "water_crop", "refill_watering_can", "harvest_crop", "plant_seed", "deposit_items", "wait", "finish"]
        },
        "args": {"type": "object"},
        "continue_on": {
          "type": "array",
          "uniqueItems": true,
          "items": {"enum": ["ALREADY_SATISFIED", "TARGET_UNREACHABLE"]}
        }
      },
      "allOf": [
        {
          "if": {"properties": {"action": {"enum": ["water_crop", "harvest_crop"]}}},
          "then": {
            "properties": {
              "args": {
                "type": "object",
                "additionalProperties": false,
                "required": ["target_id", "target_revision"],
                "properties": {
                  "target_id": {"type": "string", "minLength": 1},
                  "target_revision": {"type": "string", "minLength": 1}
                }
              }
            }
          }
        },
        {
          "if": {"properties": {"action": {"const": "move_to"}}},
          "then": {
            "properties": {
              "args": {
                "type": "object",
                "additionalProperties": false,
                "required": ["tile"],
                "properties": {
                  "tile": {"$ref": "#/$defs/tile"},
                  "tolerance_pixels": {"type": "integer", "minimum": 1, "maximum": 16},
                  "avoid_warps": {"const": true}
                }
              }
            }
          }
        },
        {
          "if": {"properties": {"action": {"const": "refill_watering_can"}}},
          "then": {
            "properties": {
              "args": {
                "type": "object",
                "additionalProperties": false,
                "properties": {"source_id": {"type": "string", "minLength": 1}}
              }
            }
          }
        },
        {
          "if": {"properties": {"action": {"const": "plant_seed"}}},
          "then": {
            "properties": {
              "args": {
                "type": "object",
                "additionalProperties": false,
                "required": ["soil_id", "soil_revision", "inventory_slot"],
                "properties": {
                  "soil_id": {"type": "string", "minLength": 1},
                  "soil_revision": {"type": "string", "minLength": 1},
                  "inventory_slot": {"type": "integer", "minimum": 0, "maximum": 35}
                }
              }
            }
          }
        },
        {
          "if": {"properties": {"action": {"const": "deposit_items"}}},
          "then": {
            "properties": {
              "args": {
                "type": "object",
                "additionalProperties": false,
                "required": ["container_id", "container_revision", "selector"],
                "properties": {
                  "container_id": {"type": "string", "minLength": 1},
                  "container_revision": {"type": "string", "minLength": 1},
                  "selector": {
                    "type": "object",
                    "additionalProperties": false,
                    "minProperties": 1,
                    "properties": {
                      "slots": {"type": "array", "items": {"type": "integer", "minimum": 0, "maximum": 35}},
                      "qualified_item_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
                      "category": {"enum": ["crop", "forage", "seed"]}
                    }
                  }
                }
              }
            }
          }
        },
        {
          "if": {"properties": {"action": {"const": "wait"}}},
          "then": {
            "properties": {
              "args": {
                "type": "object",
                "additionalProperties": false,
                "required": ["ticks"],
                "properties": {"ticks": {"type": "integer", "minimum": 1, "maximum": 300}}
              }
            }
          }
        },
        {
          "if": {"properties": {"action": {"const": "finish"}}},
          "then": {
            "properties": {
              "args": {
                "type": "object",
                "additionalProperties": false,
                "required": ["reason"],
                "properties": {"reason": {"type": "string", "minLength": 1, "maxLength": 256}}
              }
            }
          }
        }
      ]
    },
    "tile": {
      "type": "array",
      "prefixItems": [{"type": "integer"}, {"type": "integer"}],
      "items": false
    }
  }
}
